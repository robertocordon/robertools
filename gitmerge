#!/usr/bin/perl
use strict;
use warnings;

# в”Ђв”Ђ Terminal control в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
use POSIX qw();

# Save/restore terminal settings for raw-mode input
my $original_termios = POSIX::Termios->new;
$original_termios->getattr(0);

sub enable_raw_mode {
    my $raw_termios = POSIX::Termios->new;
    $raw_termios->getattr(0);
    $raw_termios->setlflag(
        $raw_termios->getlflag & ~(POSIX::ECHO | POSIX::ICANON)
    );
    $raw_termios->setcc(POSIX::VMIN,  1);
    $raw_termios->setcc(POSIX::VTIME, 0);
    $raw_termios->setattr(0, POSIX::TCSANOW);
}

sub restore_terminal {
    $original_termios->setattr(0, POSIX::TCSANOW);
}

# Make sure the terminal is always restored on exit
END { restore_terminal(); }

# в”Ђв”Ђ ANSI helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sub hide_cursor { print "\e[?25l" }
sub show_cursor { print "\e[?25h" }
sub move_up     { my ($n) = @_; print "\e[${n}A" }
sub clear_line  { print "\e[2K\r" }

# в”Ђв”Ђ Git helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sub get_local_branches {
    my $raw_output = `git branch 2>/dev/null`;
    if ($? != 0 || !defined $raw_output || $raw_output eq '') {
        die "Error: Could not list git branches. Are you inside a git repository?\n";
    }

    my @branch_list;
    for my $branch_line (split /\n/, $raw_output) {
        $branch_line =~ s/^\*?\s+//;   # strip leading "* " or spaces
        $branch_line =~ s/\s+$//;      # strip trailing whitespace
        push @branch_list, $branch_line if $branch_line ne '';
    }

    die "Error: No local branches found.\n" unless @branch_list;
    return @branch_list;
}

sub get_current_branch {
    my $current_branch = `git rev-parse --abbrev-ref HEAD 2>/dev/null`;
    chomp $current_branch;
    return $current_branch;
}

sub run_command {
    my ($command) = @_;
    print "  \e[33m\$ $command\e[0m\n";
    system($command);
    return $? == 0;
}

# в”Ђв”Ђ Interactive menu в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Returns the selected item from @options.
# $prompt        вЂ“ question shown above the menu
# $default_index вЂ“ which item is highlighted initially
# $exclude_value вЂ“ if defined, that branch name is shown dimmed and unselectable
sub interactive_menu {
    my ($prompt, $default_index, $exclude_value, @options) = @_;

    my $selected_index = $default_index // 0;
    my $num_options    = scalar @options;

    hide_cursor();
    enable_raw_mode();

    # Print the prompt once above the menu
    print "\n\e[1m$prompt\e[0m\n";

    my $render = sub {
        for my $i (0 .. $num_options - 1) {
            clear_line();
            my $branch_name = $options[$i];
            my $is_excluded = defined $exclude_value && $branch_name eq $exclude_value;

            if ($i == $selected_index) {
                if ($is_excluded) {
                    # Highlighted but invalid вЂ“ show in red
                    print "  \e[41m\e[37m В» $branch_name (already selected above) \e[0m\n";
                } else {
                    print "  \e[7m В» $branch_name \e[0m\n";
                }
            } else {
                if ($is_excluded) {
                    print "    \e[2m$branch_name\e[0m\n";
                } else {
                    print "    $branch_name\n";
                }
            }
        }
    };

    $render->();

    while (1) {
        my $key_char = '';
        sysread(STDIN, $key_char, 1);

        if ($key_char eq "\e") {
            # Escape sequence вЂ“ read two more bytes
            my $seq = '';
            sysread(STDIN, $seq, 2);
            if ($seq eq '[A') {
                # Up arrow
                $selected_index = ($selected_index - 1 + $num_options) % $num_options;
            } elsif ($seq eq '[B') {
                # Down arrow
                $selected_index = ($selected_index + 1) % $num_options;
            }
        } elsif ($key_char eq "\n" || $key_char eq "\r") {
            # Enter key
            my $chosen = $options[$selected_index];
            if (defined $exclude_value && $chosen eq $exclude_value) {
                # Flash an error and do not accept
                move_up($num_options);
                $render->();
                next;
            }
            last;
        }

        # Redraw menu in place
        move_up($num_options);
        $render->();
    }

    restore_terminal();
    show_cursor();

    # Print the final confirmed choice and clean up the menu lines
    move_up($num_options);
    for (1 .. $num_options) {
        clear_line();
        print "\n";
    }
    move_up($num_options);

    my $chosen_branch = $options[$selected_index];
    print "\e[1m$prompt\e[0m \e[32m$chosen_branch\e[0m\n";

    return $chosen_branch;
}

# в”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
my @local_branches   = get_local_branches();
my $current_branch   = get_current_branch();

# Default selection: current branch for "merge from", first other for "merge into"
my $default_source_index = 0;
for my $i (0 .. $#local_branches) {
    if ($local_branches[$i] eq $current_branch) {
        $default_source_index = $i;
        last;
    }
}

# Q1 вЂ“ branch to merge (source)
my $source_branch = interactive_menu(
    'Which branch to merge?',
    $default_source_index,
    undef,
    @local_branches
);

# Q2 вЂ“ branch to merge into (target); exclude the source branch
my $default_target_index = 0;
for my $i (0 .. $#local_branches) {
    if ($local_branches[$i] ne $source_branch) {
        $default_target_index = $i;
        last;
    }
}

my $target_branch = interactive_menu(
    'Which branch to merge into?',
    $default_target_index,
    $source_branch,
    @local_branches
);

# Q3 вЂ“ optional new branch after merge
print "\n\e[1mName of new branch?\e[0m \e[2m(leave blank to skip)\e[0m ";
restore_terminal();   # make sure canonical mode is on for normal line input
show_cursor();
my $new_branch_name = <STDIN>;
chomp $new_branch_name;
$new_branch_name =~ s/^\s+|\s+$//g;

# в”Ђв”Ђ Confirmation в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
print "\n\e[1mAbout to run:\e[0m\n";
print "  \e[33m\$ git checkout $target_branch\e[0m\n";
print "  \e[33m\$ git merge --no-ff $source_branch\e[0m\n";
print "  \e[33m\$ git branch -d $source_branch\e[0m\n";
print "  \e[33m\$ git checkout -b $new_branch_name\e[0m\n" if $new_branch_name ne '';
print "\nProceed? [y/N] ";

my $confirmation = <STDIN>;
chomp $confirmation;

unless (lc($confirmation) eq 'y') {
    print "Aborted.\n";
    exit 0;
}

# в”Ђв”Ђ Execute в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
print "\n";

unless (run_command("git checkout $target_branch")) {
    die "\e[31mError:\e[0m Failed to check out '$target_branch'. Aborting.\n";
}

unless (run_command("git merge --no-ff $source_branch")) {
    print "\e[31mMerge failed.\e[0m Leaving '$source_branch' intact. You may need to resolve conflicts.\n";
    exit 1;
}

# Only delete the source branch after a successful merge
unless (run_command("git branch -d $source_branch")) {
    print "\e[33mWarning:\e[0m Could not delete '$source_branch' (it may not be fully merged). Skipping deletion.\n";
}

if ($new_branch_name ne '') {
    unless (run_command("git checkout -b $new_branch_name")) {
        die "\e[31mError:\e[0m Failed to create new branch '$new_branch_name'.\n";
    }
}

print "\n\e[32mDone!\e[0m\n";

