#!/usr/bin/perl

use strict;
use warnings;
use POSIX qw();
use IO::Handle;

STDOUT->autoflush(1);

# ── Command definitions ───────────────────────────────────────────────────────
# Each entry is a hashref with:
#   name      - short identifier (used as CLI arg and alias name)
#   longName  - optional, human-friendly label (falls back to name in help)
#   helpText  - description shown in --help
#   commands  - arrayref of bash commands (joined with && for alias)

my @COMMANDS = (
    {
        name     => 'greet',
        longName => 'Say Hello',
        helpText => 'Prints a greeting and the current date.',
        commands => [
            'echo "Hello from workflow!"',
            'date',
        ],
    },
    {
        name     => 'listFiles',
        longName => 'List Files (detailed)',
        helpText => 'Lists all files in the current directory with details.',
        commands => [
            'ls -lah',
        ],
    },
    {
        name     => 'diskUsage',
        longName => 'Disk Usage Summary',
        helpText => 'Shows disk usage for the current directory, sorted by size.',
        commands => [
            'du -sh ./*',
        ],
    },
    {
        name     => 'sysInfo',
        longName => 'System Info',
        helpText => 'Displays OS info and uptime.',
        commands => [
            'uname -a',
            'uptime',
        ],
    },
);

# ── Install commands ──────────────────────────────────────────────────────────
# These run first when --install / -i is passed, before aliases are set.

my $VERBOSE = grep { $_ eq '-v' } @ARGV;

my @INSTALL_COMMANDS = (
    'echo "Running install steps..."',
    'echo "Install complete."',
);

# ── Terminal control ──────────────────────────────────────────────────────────

my $original_termios;

sub enable_raw_mode {
    $original_termios = POSIX::Termios->new;     # allocate empty termios struct (save slot)
    $original_termios->getattr(0);               # populate it with current terminal settings from stdin — saved for restore

    my $raw = POSIX::Termios->new;               # allocate another empty struct (this one we'll modify)
    $raw->getattr(0);                            # populate it with current settings too, so we start from a valid state

    $raw->setlflag(                              # update the "local flags" bitmask:
        $raw->getlflag & ~(POSIX::ECHO |        #   ECHO off — don't print keypresses to screen
                           POSIX::ICANON)       #   ICANON off — deliver each keypress immediately, don't wait for Enter
    );
    $raw->setcc(POSIX::VMIN,  1);               # block sysread until at least 1 character is available
    $raw->setcc(POSIX::VTIME, 0);               # no timeout — wait as long as needed
    $raw->setattr(0, POSIX::TCSANOW);           # apply modified settings to stdin immediately
}

sub restore_terminal {
    $original_termios->setattr(0, POSIX::TCSANOW) if defined $original_termios;
}

END { restore_terminal() }

# ── ANSI helpers ──────────────────────────────────────────────────────────────

sub hide_cursor { print "\e[?25l" }
sub show_cursor { print "\e[?25h" }
sub move_up     { my ($n) = @_; print "\e[${n}A" if $n > 0 }
sub clear_line  { print "\e[2K\r" }

# ── Command lookup ────────────────────────────────────────────────────────────

sub find_command {
    my ($name) = @_;
    for my $cmd (@COMMANDS) {
        return $cmd if $cmd->{name} eq $name;
    }
    return undef;
}

sub display_name {
    my ($cmd) = @_;
    return $cmd->{longName}
        ? "$cmd->{longName} ($cmd->{name})"
        : $cmd->{name};
}

# ── Execution ─────────────────────────────────────────────────────────────────

sub run_shell_command {
    my ($shell_cmd) = @_;
    print "  \e[33m\$ $shell_cmd\e[0m\n" if $VERBOSE;
    system($shell_cmd);
    return $? == 0;
}

sub run_command_entry {
    my ($cmd) = @_;
    print "\e[1mRunning: \e[0m" . display_name($cmd) . "\n";
    for my $c (@{ $cmd->{commands} }) {
        run_shell_command($c) or warn "\e[31mWarning:\e[0m command exited non-zero.\n";
    }
}

# ── Install mode ──────────────────────────────────────────────────────────────

sub run_install {
    print "\e[1mRunning install steps...\e[0m\n" if $VERBOSE;
    for my $c (@INSTALL_COMMANDS) {
        run_shell_command($c);
    }

    print "\n\e[1mSetting aliases for this session...\e[0m\n" if $VERBOSE;
    for my $cmd (@COMMANDS) {
        my $joined = join(' && ', @{ $cmd->{commands} });
        my $alias_cmd = "alias $cmd->{name}='$joined'";
        print "  \e[33m\$ $alias_cmd\e[0m\n" if $VERBOSE;
        system($alias_cmd);
    }
    print "\n\e[32mDone!\e[0m Aliases are active in this shell session.\n" if $VERBOSE;
}

# ── Help mode ─────────────────────────────────────────────────────────────────

sub print_help_all {
    print "\e[1mAvailable commands:\e[0m\n\n";
    for my $cmd (@COMMANDS) {
        printf "  \e[1m%-20s\e[0m %s\n", display_name($cmd), $cmd->{helpText};
    }
}

sub print_help_one {
    my ($name) = @_;
    my $cmd = find_command($name);
    unless ($cmd) {
        print "\e[31mError:\e[0m No command named '$name'.\n";
        exit 1;
    }
    printf "\e[1m%s\e[0m\n%s\n", display_name($cmd), $cmd->{helpText};
}

# ── Interactive selector ──────────────────────────────────────────────────────

sub interactive_select {
    my @options   = map { display_name($_) } @COMMANDS;
    my $n         = scalar @options;
    my $selected  = 0;

    hide_cursor();
    enable_raw_mode();

    print "\e[1mSelect a command:\e[0m\n";

    my $render = sub {
        for my $i (0 .. $n - 1) {
            clear_line();
            if ($i == $selected) {
                print "  \e[7m> $options[$i] \e[0m\n";
            } else {
                print "    $options[$i]\n";
            }
        }
    };

    $render->();

    while (1) {
        my $ch = '';
        sysread(STDIN, $ch, 1);

        if ($ch eq "\e") {
            my $seq = '';
            sysread(STDIN, $seq, 2);
            if    ($seq eq '[A') { $selected = ($selected - 1 + $n) % $n }
            elsif ($seq eq '[B') { $selected = ($selected + 1)      % $n }
        } elsif ($ch eq "\n" || $ch eq "\r") {
            last;
        }

        move_up($n);
        $render->();
    }

    restore_terminal();
    show_cursor();

    # Collapse menu to a single summary line
    move_up($n + 1);
    for my $i (0 .. $n) { clear_line(); print "\n" }
    move_up($n + 1);
    clear_line();
    print "\e[1mSelect a command:\e[0m \e[32m$options[$selected]\e[0m\n";

    return $COMMANDS[$selected];
}

# ── Argument parsing & dispatch ───────────────────────────────────────────────

sub main {
    my @args = @ARGV;

    # No arguments → interactive selector
    unless (@args) {
        my $cmd = interactive_select();
        run_command_entry($cmd);
        return;
    }

    my $first = $args[0];

    # --install / -i
    if ($first eq '--install' || $first eq '-i') {
        run_install();
        return;
    }

    # --help [name]
    if ($first eq '--help') {
        if (defined $args[1]) {
            print_help_one($args[1]);
        } else {
            print_help_all();
        }
        return;
    }

    # --<name>  →  run that command
    if ($first =~ /^--(.+)$/) {
        my $name = $1;
        my $cmd  = find_command($name);
        unless ($cmd) {
            print "\e[31mError:\e[0m Unknown command '$name'.\n";
            print "Run without arguments to browse commands interactively, or use --help.\n";
            exit 1;
        }
        run_command_entry($cmd);
        return;
    }

    # Unrecognised argument
    print "\e[31mError:\e[0m Unrecognised argument '$first'.\n";
    print "Usage:\n";
    print "  $0                  Interactive selector\n";
    print "  $0 --install | -i   Run install steps and set session aliases\n";
    print "  $0 --help [name]    Show help for all or one command\n";
    print "  $0 --<name>         Run a specific command\n";
    exit 1;
}

main();

