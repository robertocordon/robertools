#!/usr/bin/perl

use strict;
use warnings;
use IO::Handle;
use FindBin;
use lib "$FindBin::Bin/lib";
use Terminal;
use JSON::PP;

STDOUT->autoflush(1);

# ── Config file ───────────────────────────────────────────────────────────────

my $CONFIG_FILE = glob('~/.commandManager');

my $TEMPLATE = {
    install_commands => [
        'echo "Running install steps..."',
        'echo "Install complete."',
    ],
    commands => [
        {
            name     => 'greet',
            longName => 'Say Hello',
            helpText => 'Prints a greeting and the current date.',
            commands => [ 'echo "Hello from workflow!"', 'date' ],
            alias    => 1,
        },
        {
            name     => 'listFiles',
            longName => 'List Files (detailed)',
            helpText => 'Lists all files in the current directory with details.',
            commands => [ 'ls -lah' ],
            alias    => 'lf',
        },
        {
            name     => 'diskUsage',
            longName => 'Disk Usage Summary',
            helpText => 'Shows disk usage for the current directory, sorted by size.',
            commands => [ 'du -sh ./*' ],
            alias    => 0,
        },
        {
            name     => 'sysInfo',
            longName => 'System Info',
            helpText => 'Displays OS info and uptime.',
            commands => [ 'uname -a', 'uptime' ],
        },
    ],
};

sub write_template {
    open(my $fh, '>', $CONFIG_FILE)
        or die "${FORMAT_RED}Error:${FORMAT_RESET} Could not create '$CONFIG_FILE': $!\n";
    print $fh JSON::PP->new->utf8->pretty->encode($TEMPLATE);
    close($fh);
}

sub load_config {
    unless (-e $CONFIG_FILE) {
        print "${FORMAT_YELLOW}Warning:${FORMAT_RESET} '$CONFIG_FILE' not found. Creating template...\n";
        write_template();
        print "${FORMAT_GREEN}Created:${FORMAT_RESET} '$CONFIG_FILE' — edit it and re-run.\n";
        exit 0;
    }

    open(my $fh, '<', $CONFIG_FILE)
        or die "${FORMAT_RED}Error:${FORMAT_RESET} Could not read '$CONFIG_FILE': $!\n";
    my $raw = do { local $/; <$fh> };
    close($fh);

    my $config = eval { JSON::PP->new->utf8->decode($raw) };
    die "${FORMAT_RED}Error:${FORMAT_RESET} '$CONFIG_FILE' contains invalid JSON:\n  $@\n" if $@;

    # Validate top-level structure
    die "${FORMAT_RED}Error:${FORMAT_RESET} '$CONFIG_FILE' must contain a 'commands' array.\n"
        unless ref $config->{commands} eq 'ARRAY';
    die "${FORMAT_RED}Error:${FORMAT_RESET} '$CONFIG_FILE' must contain an 'install_commands' array.\n"
        unless ref $config->{install_commands} eq 'ARRAY';

    # Validate each command entry
    for my $i (0 .. $#{ $config->{commands} }) {
        my $cmd    = $config->{commands}[$i];
        my $prefix = "${FORMAT_RED}Error:${FORMAT_RESET} Command #" . ($i + 1) . " in '$CONFIG_FILE'";
        die "$prefix is missing required field 'name'.\n"
            unless defined $cmd->{name} && $cmd->{name} =~ /\S/;
        die "$prefix is missing required field 'helpText'.\n"
            unless defined $cmd->{helpText} && $cmd->{helpText} =~ /\S/;
        die "$prefix 'commands' must be a non-empty array.\n"
            unless ref $cmd->{commands} eq 'ARRAY' && @{ $cmd->{commands} };
    }

    return $config;
}

# ── Load config ───────────────────────────────────────────────────────────────

my $SCRIPT_PATH = do {
    use Cwd 'abs_path';
    abs_path($0);
};

my $config           = load_config();
my @COMMANDS         = @{ $config->{commands} };
my @INSTALL_COMMANDS = @{ $config->{install_commands} };

# ── Verbose flag ──────────────────────────────────────────────────────────────

my $VERBOSE = grep { $_ eq '-v' } @ARGV;

# ── Command lookup ────────────────────────────────────────────────────────────

sub resolve_alias {
    my ($cmd) = @_;
    my $a = $cmd->{alias};
    return undef unless defined $a && $a;   # 0 or absent → no alias
    return $a eq '1' ? $cmd->{name} : $a;  # 1 → use name, string → use string
}

sub find_command {
    my ($name) = @_;
    for my $cmd (@COMMANDS) {
        return $cmd if $cmd->{name} eq $name;
    }
    return undef;
}

sub display_name {
    my ($cmd) = @_;
    return $cmd->{longName}
        ? "$cmd->{longName} ($cmd->{name})"
        : $cmd->{name};
}

# ── Execution ─────────────────────────────────────────────────────────────────

sub run_shell_command {
    my ($shell_cmd) = @_;
    print STDERR "  ${FORMAT_YELLOW}\$ $shell_cmd${FORMAT_RESET}\n" if $VERBOSE;
    system($shell_cmd . ' >&2');
    return $? == 0;
}

sub run_command_entry {
    my ($cmd) = @_;
    print "${FORMAT_BOLD}Running: ${FORMAT_RESET}" . display_name($cmd) . "\n";
    for my $c (@{ $cmd->{commands} }) {
        run_shell_command($c) or warn "${FORMAT_RED}Warning:${FORMAT_RESET} command exited non-zero.\n";
    }
}

# ── Install mode ──────────────────────────────────────────────────────────────

sub run_install {
    print STDERR "${FORMAT_BOLD}Running install steps...${FORMAT_RESET}\n" if $VERBOSE;
    for my $c (@INSTALL_COMMANDS) {
        run_shell_command($c);
    }

    print STDERR "\n${FORMAT_BOLD}Setting aliases for this session...${FORMAT_RESET}\n" if $VERBOSE;
    for my $cmd (@COMMANDS) {
        my $alias = resolve_alias($cmd);
        next unless defined $alias;
        my $alias_cmd = "alias $alias='$SCRIPT_PATH --$cmd->{name}'";
        print STDERR "  ${FORMAT_YELLOW}\$ $alias_cmd${FORMAT_RESET}\n" if $VERBOSE;
        print "$alias_cmd;";
    }
    print STDERR "\n${FORMAT_GREEN}Done!${FORMAT_RESET} Aliases are active in this shell session.\n" if $VERBOSE;
}

# ── Help mode ─────────────────────────────────────────────────────────────────

sub print_help_all {
    print "${FORMAT_BOLD}Available commands:${FORMAT_RESET}\n\n";
    for my $cmd (@COMMANDS) {
        print_help_one($cmd->{name});
    }
}

sub print_help_one {
    my ($name) = @_;
    my $cmd = find_command($name);
    unless ($cmd) {
        print "${FORMAT_RED}Error:${FORMAT_RESET} No command named '$name'.\n";
        exit 1;
    }
    printf "${FORMAT_BOLD}%s${FORMAT_RESET}\n%s\n", display_name($cmd), $cmd->{helpText};
}

# ── Argument parsing & dispatch ───────────────────────────────────────────────

sub main {
    my @args = grep { $_ ne '-v' } @ARGV;

    # No arguments → interactive selector
    unless (@args) {
        my @options = map { display_name($_) } @COMMANDS;
        my $idx = interactive_select('Select a command:', \@options);
        run_command_entry($COMMANDS[$idx]);
        return;
    }

    my $first = $args[0];

    # --install / -i
    if ($first eq '--install' || $first eq '-i') {
        run_install();
        return;
    }

    # --help [name]
    if ($first eq '--help') {
        if (defined $args[1]) {
            print_help_one($args[1]);
        } else {
            print_help_all();
        }
        return;
    }

    # --<name>  →  run that command
    if ($first =~ /^--(.+)$/) {
        my $name = $1;
        my $cmd  = find_command($name);
        unless ($cmd) {
            print "${FORMAT_RED}Error:${FORMAT_RESET} Unknown command '$name'.\n";
            print "Run without arguments to browse commands interactively, or use --help.\n";
            exit 1;
        }
        run_command_entry($cmd);
        return;
    }

    # Unrecognised argument
    print "${FORMAT_RED}Error:${FORMAT_RESET} Unrecognised argument '$first'.\n";
    print "Usage:\n";
    print "  $0                  Interactive selector\n";
    print "  $0 --install | -i   Run install steps and set session aliases\n";
    print "  $0 --help [name]    Show help for all or one command\n";
    print "  $0 --<name>         Run a specific command\n";
    exit 1;
}

main();
